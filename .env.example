# SkillSewa Environment Variables
# Copy this file to .env and fill in your values

# ─── DATABASE ───────────────────────────────────────────────────────────────
# MySQL connection string
DATABASE_URL="mysql://root:password@localhost:3306/skillsewa"

# ─── AUTH ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-here-min-32-chars"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── NEXTAUTH ───────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI ENGINE ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key"
# OR
OPENAI_API_KEY="your-openai-api-key"

# ─── NOTIFICATIONS ──────────────────────────────────────────────────────────
# Sparrow SMS (Nepal)
SPARROW_SMS_TOKEN="your-sparrow-sms-token"
SPARROW_SMS_FROM="SkillSewa"

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Firebase (Push)
FIREBASE_SERVER_KEY="your-firebase-server-key"
FIREBASE_PROJECT_ID="your-firebase-project-id"

# ─── PAYMENTS ───────────────────────────────────────────────────────────────
# eSewa
ESEWA_MERCHANT_ID="your-esewa-merchant-id"
ESEWA_SECRET_KEY="your-esewa-secret"
ESEWA_API_URL="https://uat.esewa.com.np"

# Khalti
KHALTI_SECRET_KEY="your-khalti-secret"
KHALTI_API_URL="https://khalti.com/api/v2"

# ─── MAPS ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ─── APP CONFIG ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Skill-Sewa"
NODE_ENV="development"

# Business Rules (change without code deploy)
CONNECTION_FEE=10
SERVICE_COMMISSION_RATE=0.10
PLATFORM_SHARE_RATE=0.05
WORKER_BONUS_SHARE_RATE=0.05
SUPPLIER_REFERRAL_RATE=0.02
SUPPLIER_PLATFORM_SHARE=0.01
SUPPLIER_WORKER_BONUS_SHARE=0.01
MIN_WITHDRAWAL_AMOUNT=500
WORKER_SEARCH_RADIUS_KM=5
