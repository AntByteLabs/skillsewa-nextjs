// SkillSewa — Full Production Prisma Schema
// MySQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  PROFESSIONAL
  SUPPLIER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  ESEWA
  KHALTI
  CASH
  WALLET
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  LOCK
  UNLOCK
  REFUND
  WITHDRAWAL
  COMMISSION
  REFERRAL_COMMISSION
}

enum WalletTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum NotificationChannel {
  IN_APP
  SMS
  WHATSAPP
  PUSH
  EMAIL
}

enum NotificationType {
  BOOKING_NEW
  BOOKING_CONFIRMED
  BOOKING_COMPLETED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  WALLET_CREDITED
  WALLET_DEBITED
  WALLET_UNLOCKED
  ORDER_PLACED
  ORDER_SHIPPED
  ORDER_DELIVERED
  REVIEW_RECEIVED
  SYSTEM_ALERT
  PROMOTION
}

enum ProfessionalGrade {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  ELITE
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

enum SkillRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductCategory {
  TOOLS
  EQUIPMENT
  CLEANING_SUPPLIES
  SAFETY_GEAR
  PARTS
  MATERIALS
  OTHER
}

// ─── CORE: USERS ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  email        String?  @unique
  name         String
  passwordHash String   @map("password_hash")
  role         UserRole @default(CUSTOMER)
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  isVerified   Boolean  @default(false) @map("is_verified")
  locationLat  Decimal? @map("location_lat") @db.Decimal(10, 7)
  locationLng  Decimal? @map("location_lng") @db.Decimal(10, 7)
  address      String?
  city         String?
  fcmToken     String?  @map("fcm_token")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  professional     Professional?
  supplier         Supplier?
  bookingsAsCustomer Booking[]      @relation("CustomerBookings")
  ordersAsCustomer   Order[]        @relation("CustomerOrders")
  wallet             Wallet?
  notifications      Notification[]
  reviewsGiven       Review[]       @relation("ReviewsGiven")
  reviewsReceived    Review[]       @relation("ReviewsReceived")
  refreshTokens      RefreshToken[]

  @@index([phone])
  @@index([role])
  @@index([locationLat, locationLng])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── PROFESSIONAL ─────────────────────────────────────────────────────────────

model Professional {
  id               String            @id @default(cuid())
  userId           String            @unique @map("user_id")
  bio              String?           @db.Text
  grade            ProfessionalGrade @default(BRONZE)
  ratingAvg        Decimal           @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount      Int               @default(0) @map("rating_count")
  jobsCount        Int               @default(0) @map("jobs_count")
  jobsCompleted    Int               @default(0) @map("jobs_completed")
  isAvailable      Boolean           @default(true) @map("is_available")
  isVerified       Boolean           @default(false) @map("is_verified")
  responseRate     Decimal           @default(100) @map("response_rate") @db.Decimal(5, 2)
  loyaltyMonths    Int               @default(0) @map("loyalty_months")
  idDocumentUrl    String?           @map("id_document_url")
  certificationUrl String?           @map("certification_url")
  verifiedAt       DateTime?         @map("verified_at")
  verifiedByAdminId String?          @map("verified_by_admin_id")
  // ── Referral ──────────────────────────────────────────────────
  referralCode     String?           @unique @map("referral_code") @db.VarChar(16)
  referredById     String?           @map("referred_by_id")
  referralEarnings Decimal           @default(0) @map("referral_earnings") @db.Decimal(12, 2)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillCategories ProfessionalSkillCategory[]
  skillRequests   SkillRequest[]
  bookings        Booking[]                  @relation("ProfessionalBookings")
  schedule        ProfessionalSchedule[]
  leaves          ProfessionalLeave[]
  earnings        ProfessionalEarning[]
  // Referral self-relations
  referredBy      Professional?              @relation("ReferralTree", fields: [referredById], references: [id], onDelete: SetNull)
  referrals       Professional[]             @relation("ReferralTree")
  referralsMade   ProfessionalReferral[]     @relation("ReferrerEarnings")
  referralSource  ProfessionalReferral?      @relation("ReferredProfessional")

  @@index([userId])
  @@index([isAvailable])
  @@index([grade])
  @@index([referralCode])
  @@index([referredById])
  @@map("professionals")
}

model ProfessionalReferral {
  id             String   @id @default(cuid())
  referrerId     String   @map("referrer_id")
  referredId     String   @unique @map("referred_id")
  bookingId      String?  @map("booking_id")
  amount         Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  referrer Professional @relation("ReferrerEarnings", fields: [referrerId], references: [id])
  referred Professional @relation("ReferredProfessional", fields: [referredId], references: [id])

  @@index([referrerId])
  @@map("professional_referrals")
}

model ServiceCategory {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  nameNp      String? @map("name_np")
  description String? @db.Text
  iconUrl     String? @map("icon_url")
  imageUrl    String? @map("image_url")
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")

  professionals ProfessionalSkillCategory[]
  skillRequests SkillRequest[]
  services      Service[]

  @@index([code])
  @@map("service_categories")
}

model ProfessionalSkillCategory {
  id             String @id @default(cuid())
  professionalId String @map("professional_id")
  categoryId     String @map("category_id")
  yearsExp       Int    @default(0) @map("years_exp")

  professional Professional    @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  category     ServiceCategory @relation(fields: [categoryId], references: [id])

  @@unique([professionalId, categoryId])
  @@map("professional_skill_categories")
}

model ProfessionalSchedule {
  id             String  @id @default(cuid())
  professionalId String  @map("professional_id")
  dayOfWeek      Int     @map("day_of_week") // 0=Sun...6=Sat
  startTime      String  @map("start_time") // "09:00"
  endTime        String  @map("end_time")   // "18:00"
  isAvailable    Boolean @default(true) @map("is_available")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
  @@map("professional_schedules")
}

model ProfessionalLeave {
  id             String   @id @default(cuid())
  professionalId String   @map("professional_id")
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([startDate, endDate])
  @@map("professional_leaves")
}

model ProfessionalEarning {
  id             String   @id @default(cuid())
  professionalId String   @map("professional_id")
  bookingId      String?  @map("booking_id")
  amount         Decimal  @db.Decimal(10, 2)
  commission     Decimal  @db.Decimal(10, 2)
  netAmount      Decimal  @map("net_amount") @db.Decimal(10, 2)
  bonusShare     Decimal  @map("bonus_share") @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  professional Professional @relation(fields: [professionalId], references: [id])

  @@index([professionalId])
  @@map("professional_earnings")
}

model SkillRequest {
  id             String             @id @default(cuid())
  professionalId String             @map("professional_id")
  categoryId     String             @map("category_id")
  yearsExp       Int                @default(0) @map("years_exp")
  documentUrl    String?            @map("document_url") @db.Text
  status         SkillRequestStatus @default(PENDING)
  adminNote      String?            @map("admin_note") @db.Text
  reviewedAt     DateTime?          @map("reviewed_at")
  reviewedBy     String?            @map("reviewed_by")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  professional Professional    @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  category     ServiceCategory @relation(fields: [categoryId], references: [id])

  @@index([professionalId])
  @@index([status])
  @@map("skill_requests")
}

// ─── SUPPLIER ─────────────────────────────────────────────────────────────────

model Supplier {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  businessName    String   @map("business_name")
  businessRegNo   String?  @map("business_reg_no")
  description     String?  @db.Text
  logoUrl         String?  @map("logo_url")
  isVerified      Boolean  @default(false) @map("is_verified")
  rating          Decimal  @default(0) @db.Decimal(3, 2)
  ratingCount     Int      @default(0) @map("rating_count")
  totalSales      Int      @default(0) @map("total_sales")
  locationAddress String?  @map("location_address")
  locationLat     Decimal? @map("location_lat") @db.Decimal(10, 7)
  locationLng     Decimal? @map("location_lng") @db.Decimal(10, 7)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("suppliers")
}

// ─── SERVICES ─────────────────────────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  categoryId  String   @map("category_id")
  name        String
  nameNp      String?  @map("name_np")
  description String?  @db.Text
  basePrice   Decimal  @map("base_price") @db.Decimal(10, 2)
  priceUnit   String   @default("per_visit") @map("price_unit")
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  isFeatured    Boolean  @default(false) @map("is_featured")
  minPrice      Decimal? @map("min_price") @db.Decimal(10, 2)
  maxPrice      Decimal? @map("max_price") @db.Decimal(10, 2)
  durationMin   Int      @default(60) @map("duration_min") // estimated minutes

  category      ServiceCategory @relation(fields: [categoryId], references: [id])
  bookings      Booking[]
  issues        ServiceIssue[]

  @@index([categoryId])
  @@map("services")
}

// Issues / problem types that can be reported within a service
model ServiceIssue {
  id          String   @id @default(cuid())
  serviceId   String   @map("service_id")
  name        String                         // e.g. "Leaking tap"
  nameNp      String?  @map("name_np")
  description String?  @db.Text
  basePrice   Decimal  @map("base_price") @db.Decimal(10, 2)  // estimated price for this issue
  minPrice    Decimal  @map("min_price") @db.Decimal(10, 2)
  maxPrice    Decimal  @map("max_price") @db.Decimal(10, 2)
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  service      Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookingIssues BookingIssue[]

  @@index([serviceId])
  @@map("service_issues")
}

// ─── BOOKINGS ─────────────────────────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  customerId      String        @map("customer_id")
  professionalId  String?       @map("professional_id")
  serviceId       String        @map("service_id")
  status          BookingStatus @default(PENDING)
  scheduledAt     DateTime?     @map("scheduled_at")
  startedAt       DateTime?     @map("started_at")
  completedAt     DateTime?     @map("completed_at")
  cancelledAt     DateTime?     @map("cancelled_at")
  cancelReason    String?       @map("cancel_reason") @db.Text
  cancelledBy     String?       @map("cancelled_by")
  addressLine     String?       @map("address_line")
  locationLat     Decimal?      @map("location_lat") @db.Decimal(10, 7)
  locationLng     Decimal?      @map("location_lng") @db.Decimal(10, 7)
  notes           String?       @db.Text
  estimatedPrice  Decimal?      @map("estimated_price") @db.Decimal(10, 2)
  quotedPrice     Decimal?      @map("quoted_price") @db.Decimal(10, 2)
  finalPrice      Decimal?      @map("final_price") @db.Decimal(10, 2)
  connectionFee   Decimal       @default(10) @map("connection_fee") @db.Decimal(10, 2)
  platformRevenue Decimal?      @map("platform_revenue") @db.Decimal(10, 2)
  walletCredit    Decimal?      @map("wallet_credit") @db.Decimal(10, 2)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  customer     User          @relation("CustomerBookings", fields: [customerId], references: [id])
  professional Professional? @relation("ProfessionalBookings", fields: [professionalId], references: [id])
  service      Service       @relation(fields: [serviceId], references: [id])
  payment      Payment?
  review       Review?
  issues       BookingIssue[]
  priceAdjustments PriceAdjustment[]

  @@index([customerId])
  @@index([professionalId])
  @@index([status])
  @@index([scheduledAt])
  @@map("bookings")
}

// Issues selected by the customer when booking
model BookingIssue {
  id             String  @id @default(cuid())
  bookingId      String  @map("booking_id")
  serviceIssueId String  @map("service_issue_id")
  priceAtBooking Decimal @map("price_at_booking") @db.Decimal(10, 2)

  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceIssue ServiceIssue @relation(fields: [serviceIssueId], references: [id])

  @@unique([bookingId, serviceIssueId])
  @@map("booking_issues")
}

// Additional charges added by professional after inspection
model PriceAdjustment {
  id           String   @id @default(cuid())
  bookingId    String   @map("booking_id")
  description  String
  amount       Decimal  @db.Decimal(10, 2)
  isApproved   Boolean  @default(false) @map("is_approved")
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("price_adjustments")
}

// ─── PRODUCTS ─────────────────────────────────────────────────────────────────

model Product {
  id              String          @id @default(cuid())
  supplierId      String          @map("supplier_id")
  name            String
  nameNp          String?         @map("name_np")
  slug            String          @unique
  description     String?         @db.Text
  category        ProductCategory @default(OTHER)
  price           Decimal         @db.Decimal(10, 2)
  comparePrice    Decimal?        @map("compare_price") @db.Decimal(10, 2)
  stock           Int             @default(0)
  sku             String?         @unique
  unit            String          @default("piece")
  imageUrl        String?         @map("image_url")
  images          Json?
  isActive        Boolean         @default(true) @map("is_active")
  isFeatured      Boolean         @default(false) @map("is_featured")
  totalSold       Int             @default(0) @map("total_sold")
  rating          Decimal         @default(0) @db.Decimal(3, 2)
  ratingCount     Int             @default(0) @map("rating_count")
  weight          Decimal?        @db.Decimal(8, 2)
  dimensions      String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  supplier   Supplier    @relation(fields: [supplierId], references: [id])
  orderItems OrderItem[]

  @@index([supplierId])
  @@index([category])
  @@index([slug])
  @@map("products")
}

// ─── ORDERS ──────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  customerId      String      @map("customer_id")
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  discount        Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  shippingAddress String?     @map("shipping_address")
  notes           String?     @db.Text
  confirmedAt     DateTime?   @map("confirmed_at")
  shippedAt       DateTime?   @map("shipped_at")
  deliveredAt     DateTime?   @map("delivered_at")
  cancelledAt     DateTime?   @map("cancelled_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  customer  User        @relation("CustomerOrders", fields: [customerId], references: [id])
  items     OrderItem[]
  payment   Payment?

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─── PAYMENTS ─────────────────────────────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  bookingId       String?       @unique @map("booking_id")
  orderId         String?       @unique @map("order_id")
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  gatewayRef      String?       @map("gateway_ref")
  gatewayResponse Json?         @map("gateway_response")
  paidAt          DateTime?     @map("paid_at")
  refundedAt      DateTime?     @map("refunded_at")
  refundAmount    Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  booking Booking? @relation(fields: [bookingId], references: [id])
  order   Order?   @relation(fields: [orderId], references: [id])

  @@index([status])
  @@map("payments")
}

// ─── WALLET ───────────────────────────────────────────────────────────────────

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  totalBalance     Decimal  @default(0) @map("total_balance") @db.Decimal(12, 2)
  availableBalance Decimal  @default(0) @map("available_balance") @db.Decimal(12, 2)
  lockedBalance    Decimal  @default(0) @map("locked_balance") @db.Decimal(12, 2)
  lifetimeEarned   Decimal  @default(0) @map("lifetime_earned") @db.Decimal(12, 2)
  lifetimeSpent    Decimal  @default(0) @map("lifetime_spent") @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  locks        WalletLock[]
  withdrawals  Withdrawal[]

  @@map("wallets")
}

model WalletTransaction {
  id          String                  @id @default(cuid())
  walletId    String                  @map("wallet_id")
  type        WalletTransactionType
  status      WalletTransactionStatus @default(PENDING)
  amount      Decimal                 @db.Decimal(12, 2)
  balanceBefore Decimal               @map("balance_before") @db.Decimal(12, 2)
  balanceAfter  Decimal               @map("balance_after") @db.Decimal(12, 2)
  description String?
  referenceId String?                 @map("reference_id")
  referenceType String?               @map("reference_type")
  metadata    Json?
  createdAt   DateTime                @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model WalletLock {
  id          String    @id @default(cuid())
  walletId    String    @map("wallet_id")
  amount      Decimal   @db.Decimal(12, 2)
  reason      String
  bookingId   String?   @map("booking_id")
  unlockedAt  DateTime? @map("unlocked_at")
  unlockCondition Json? @map("unlock_condition")
  expiresAt   DateTime? @map("expires_at")
  isLocked    Boolean   @default(true) @map("is_locked")
  createdAt   DateTime  @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([isLocked])
  @@map("wallet_locks")
}

model Withdrawal {
  id          String           @id @default(cuid())
  walletId    String           @map("wallet_id")
  amount      Decimal          @db.Decimal(12, 2)
  status      WithdrawalStatus @default(PENDING)
  method      String
  accountDetails Json?         @map("account_details")
  adminNote   String?          @map("admin_note") @db.Text
  processedAt DateTime?        @map("processed_at")
  processedBy String?          @map("processed_by")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([status])
  @@map("withdrawals")
}

// ─── REVIEWS ─────────────────────────────────────────────────────────────────

model Review {
  id             String   @id @default(cuid())
  bookingId      String   @unique @map("booking_id")
  reviewerId     String   @map("reviewer_id")
  revieweeId     String   @map("reviewee_id")
  rating         Int
  comment        String?  @db.Text
  isPublic       Boolean  @default(true) @map("is_public")
  professionalReply String? @map("professional_reply") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  booking  Booking @relation(fields: [bookingId], references: [id])
  reviewer User    @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee User    @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@index([revieweeId])
  @@index([rating])
  @@map("reviews")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id          String              @id @default(cuid())
  userId      String              @map("user_id")
  type        NotificationType
  channel     NotificationChannel @default(IN_APP)
  title       String
  body        String              @db.Text
  data        Json?
  isRead      Boolean             @default(false) @map("is_read")
  readAt      DateTime?           @map("read_at")
  sentAt      DateTime?           @map("sent_at")
  failedAt    DateTime?           @map("failed_at")
  error       String?
  createdAt   DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── PLATFORM CONFIG ──────────────────────────────────────────────────────────

model PlatformConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by")

  @@map("platform_configs")
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
